<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:MigraineTracker.Views"
       x:Class="MigraineTracker.AppShell">

    <TabBar>

        <Tab Title="Accueil" Icon="icon_accueil.png">
            <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" />
        </Tab>
        
        <Tab Title="Calendrier" Icon="icon_Calendrier.png">
            <ShellContent ContentTemplate="{DataTemplate views:CalendarPage}" />
        </Tab>
        
        <Tab Title="Historique" Icon="icon_Historique.png">
            <ShellContent ContentTemplate="{DataTemplate views:HistoryPage}" />
        </Tab>
        
        <Tab Title="Stats" Icon="icon_Stats.png">
            <ShellContent ContentTemplate="{DataTemplate views:StatsPage}" />
        </Tab>

    </TabBar>

</Shell>