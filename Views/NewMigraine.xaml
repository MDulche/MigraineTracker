<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MigraineTracker.Views.NewMigraine"
             Title="Nouvelle Migraine"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="20">

            <VerticalStackLayout Spacing="6">
                <Label Text="Début" TextColor="{StaticResource TextPrimary}" />
                <DatePicker Date="{Binding StartDate}" />
                <TimePicker Time="{Binding StartTimeOfDay}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <HorizontalStackLayout>
                    <CheckBox IsChecked="{Binding HasEndTime}"/>
                    <Label Text="Fin" TextColor="{StaticResource TextPrimary}" />
                </HorizontalStackLayout>
                <DatePicker Date="{Binding EndDate}" IsVisible="{Binding HasEndTime}"/>
                <TimePicker Time="{Binding EndTimeOfDay}" IsVisible="{Binding HasEndTime}"/>
            </VerticalStackLayout>
            
            <VerticalStackLayout Spacing="6">
                <Label Text="Intensité" TextColor="{StaticResource TextPrimary}"/>
                <Slider Minimum="1" Maximum="10" Value="{Binding Intensity}" />
                <Label Text="{Binding Intensity, StringFormat='{0:F0}/10'}" TextColor="{StaticResource TextPrimary}"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="Cause probable" TextColor="{StaticResource TextPrimary}"/>
                <Editor Text="{Binding ProbableCause}" HeightRequest="100" TextColor="{StaticResource TextPrimary}" BackgroundColor="{StaticResource Surface}"/>
            </VerticalStackLayout>
            
            <VerticalStackLayout Spacing="6">
                <Label Text="Symptômes avant" TextColor="{StaticResource TextPrimary}"/>
                <Entry Text="{Binding SymptomsBefore}" TextColor="{StaticResource TextPrimary}" BackgroundColor="{StaticResource Surface}"/>
            </VerticalStackLayout>
            
            <VerticalStackLayout Spacing="6">
                <Label Text="Symptômes pendant" TextColor="{StaticResource TextPrimary}"/>
                <Entry Text="{Binding SymptomsDuring}" TextColor="{StaticResource TextPrimary}" BackgroundColor="{StaticResource Surface}"/>
            </VerticalStackLayout>
            
            <VerticalStackLayout Spacing="6">
                <Label Text="Notes" TextColor="{StaticResource TextPrimary}"/>
                <Editor Text="{Binding Notes}" HeightRequest="100" TextColor="{StaticResource TextPrimary}" BackgroundColor="{StaticResource Surface}"/>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="Annuler" Command="{Binding CancelCommand }" />
                <Button Grid.Column="1" Text="Enregistrer" Command="{Binding SaveCommand }" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>
